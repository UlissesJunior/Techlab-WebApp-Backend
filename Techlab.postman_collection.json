		{
			"name": "Transactions",
			"item": [
				{
					"name": "Adicionar Despesa",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();\r",
									"\r",
									"pm.test('Balance should be equal to the difference of account balance and amount from payload', () => {\r",
									"    if(pm.expect(response.accountOrigin.balance).to.equal(pm.collectionVariables.get('account1.balance') - pm.request.body.amount)) {\r",
									"        pm.expect(response.accountOrigin.balance).to.equal(pm.collectionVariables.get('account1.balance') - pm.request.body.amount)\r",
									"        pm.environment.set(\"account1.balance\", pm.response.json().accountOrigin.balance);\r",
									"    }\r",
									"});\r",
									""
								],
