						"description": "Generated from cURL: curl -X POST http://localhost:3000/users \\\r\n  -H \"Content-Type: application/json\" \\\r\n  -d '{\"name\":\"Ulisses\",\"email\":\"ulisses@example.com\",\"password\":\"123456\"}'\r\n"
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Verify access token in the response\", function () {\r",
									"    pm.response.to.have.jsonBody('accessToken');\r",
									"});\r",
									"\r",
									"pm.environment.set(\"jwt_token\", pm.response.json().accessToken);"
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
