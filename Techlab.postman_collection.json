				{
					"name": "Criar Conta",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {\r",
									"    pm.response.to.have.status(201);\r",
									"});\r",
									"\r",
									"pm.test(\"Response contains user ID\", function () {\r",
									"    pm.response.to.have.jsonBody('id');\r",
									"});"
